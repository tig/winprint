<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WinPrint.Maui.MainPage"
             Title="{Binding Title}">

    <ContentPage.MenuBarItems>
        <MenuBarItem Text="File">
            <MenuFlyoutItem Text="Open..." Command="{Binding OpenFileCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="O" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Print..." Command="{Binding PrintCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="P" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
        </MenuBarItem>
        <MenuBarItem Text="View">
            <MenuFlyoutItem Text="Refresh" Command="{Binding RefreshCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F5" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Zoom In" Command="{Binding ZoomInCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="OemPlus" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Zoom Out" Command="{Binding ZoomOutCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="OemMinus" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Zoom to Fit" Command="{Binding ZoomFitCommand}">
                <MenuFlyoutItem.KeyboardAccelerators>
                    <KeyboardAccelerator Modifiers="Ctrl" Key="D0" />
                </MenuFlyoutItem.KeyboardAccelerators>
            </MenuFlyoutItem>
        </MenuBarItem>
        <MenuBarItem Text="Navigate">
            <MenuFlyoutItem Text="Next Page" Command="{Binding NextPageCommand}" />
            <MenuFlyoutItem Text="Previous Page" Command="{Binding PreviousPageCommand}" />
            <MenuFlyoutItem Text="First Page" Command="{Binding FirstPageCommand}" />
            <MenuFlyoutItem Text="Last Page" Command="{Binding LastPageCommand}" />
        </MenuBarItem>
    </ContentPage.MenuBarItems>

    <Grid ColumnDefinitions="240,*">

        <!-- LEFT PANEL: Settings -->
        <ScrollView Grid.Column="0"
                    BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}">
            <VerticalStackLayout Padding="6,4" Spacing="2">

                <!-- File / Print / Settings buttons -->
                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="3">
                    <Button Grid.Column="0" Text="📂 File..." Command="{Binding OpenFileCommand}" FontSize="11" HeightRequest="26" Padding="2,0" />
                    <Button Grid.Column="1" Text="🖶 Print..." Command="{Binding PrintCommand}" FontSize="11" HeightRequest="26" Padding="2,0" />
                    <Button Grid.Column="2" Text="⚙" Command="{Binding SettingsCommand}" WidthRequest="26" HeightRequest="26" FontSize="11" Padding="0" />
                </Grid>

                <!-- Sheet Definition group (collapsible, contains all sheet settings) -->
                <Border Stroke="Gray" StrokeThickness="1" Padding="6,2" Margin="0,4,0,0"
                        StrokeShape="RoundRectangle 3">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="SheetDefHeader" Text="▼ Sheet Definition" FontAttributes="Bold" FontSize="11">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSheetDefHeaderTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <VerticalStackLayout x:Name="SheetDefContent" Spacing="2">
                            <!-- Sheet selector -->
                            <Picker ItemsSource="{Binding SheetNames}"
                                    SelectedIndex="{Binding SelectedSheetIndex}"
                                    FontSize="11" />
                            <HorizontalStackLayout Spacing="4">
                                <CheckBox IsChecked="{Binding Landscape}" VerticalOptions="Center" Scale="0.75" />
                                <Label Text="Landscape" VerticalOptions="Center" FontSize="11" />
                            </HorizontalStackLayout>

                            <!-- Margins (collapsible sub-section) -->
                            <VerticalStackLayout Spacing="1">
                                <Label x:Name="MarginsHeader" Text="▼ Margins" FontAttributes="Bold" FontSize="10" Margin="0,2,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnMarginsHeaderTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Grid x:Name="MarginsContent" ColumnDefinitions="48,56,Auto,12,42,56,Auto" RowDefinitions="28,28" RowSpacing="1" ColumnSpacing="1" Margin="4,0,0,0">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Top:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                    <Entry Grid.Row="0" Grid.Column="1" Text="{Binding MarginTop}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                    <Stepper Grid.Row="0" Grid.Column="2" Value="{Binding MarginTopValue}" Minimum="0" Maximum="5" Increment="0.05" Scale="0.6" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="Bottom:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                    <Entry Grid.Row="1" Grid.Column="1" Text="{Binding MarginBottom}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                    <Stepper Grid.Row="1" Grid.Column="2" Value="{Binding MarginBottomValue}" Minimum="0" Maximum="5" Increment="0.05" Scale="0.6" VerticalOptions="Center" />
                                    <Label Grid.Row="0" Grid.Column="4" Text="Left:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                    <Entry Grid.Row="0" Grid.Column="5" Text="{Binding MarginLeft}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                    <Stepper Grid.Row="0" Grid.Column="6" Value="{Binding MarginLeftValue}" Minimum="0" Maximum="5" Increment="0.05" Scale="0.6" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="4" Text="Right:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                    <Entry Grid.Row="1" Grid.Column="5" Text="{Binding MarginRight}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                    <Stepper Grid.Row="1" Grid.Column="6" Value="{Binding MarginRightValue}" Minimum="0" Maximum="5" Increment="0.05" Scale="0.6" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Multiple Pages Up (collapsible sub-section) -->
                            <VerticalStackLayout Spacing="1">
                                <Label x:Name="PagesUpHeader" Text="▼ Multiple Pages Up" FontAttributes="Bold" FontSize="10" Margin="0,2,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPagesUpHeaderTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <VerticalStackLayout x:Name="PagesUpContent" Spacing="1" Margin="4,0,0,0">
                                    <Grid ColumnDefinitions="62,52" RowDefinitions="28,28,28" RowSpacing="1" ColumnSpacing="4">
                                        <Label Grid.Row="0" Grid.Column="0" Text="Rows:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                        <Entry Grid.Row="0" Grid.Column="1" Text="{Binding Rows}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                        <Label Grid.Row="1" Grid.Column="0" Text="Columns:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                        <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Columns}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                        <Label Grid.Row="2" Grid.Column="0" Text="Padding:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="End" />
                                        <Entry Grid.Row="2" Grid.Column="1" Text="{Binding PaddingValue}" Keyboard="Numeric" FontSize="10" HeightRequest="26" />
                                    </Grid>
                                    <HorizontalStackLayout Spacing="4">
                                        <CheckBox IsChecked="{Binding PageSeparator}" VerticalOptions="Center" Scale="0.75" />
                                        <Label Text="Page Separator" VerticalOptions="Center" FontSize="10" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <!-- Fonts -->
                            <VerticalStackLayout Spacing="1" Margin="0,2,0,0">
                                <Label Text="Content font:" FontSize="10" />
                                <Label Text="{Binding ContentFontDescription}" FontSize="10" TextColor="{AppThemeBinding Light=Blue, Dark=LightBlue}" TextDecorations="Underline">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ChangeContentFontCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Text="Header/Footer font:" FontSize="10" />
                                <Label Text="{Binding HeaderFooterFontDescription}" FontSize="10" TextColor="{AppThemeBinding Light=Blue, Dark=LightBlue}" TextDecorations="Underline">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ChangeHeaderFooterFontCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>

                            <!-- Line Numbers -->
                            <HorizontalStackLayout Spacing="4">
                                <CheckBox IsChecked="{Binding LineNumbers}" VerticalOptions="Center" Scale="0.75" />
                                <Label Text="Line Numbers" VerticalOptions="Center" FontSize="11" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Printer group (collapsible) -->
                <Border Stroke="Gray" StrokeThickness="1" Padding="6,2" Margin="0,4,0,0"
                        StrokeShape="RoundRectangle 3">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="PrinterHeader" Text="▼ Printer" FontAttributes="Bold" FontSize="11">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPrinterHeaderTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <VerticalStackLayout x:Name="PrinterContent" Spacing="2">
                            <Picker ItemsSource="{Binding PrinterNames}"
                                    SelectedItem="{Binding SelectedPrinter}"
                                    FontSize="11" />
                            <Label Text="Paper:" FontSize="10" />
                            <Picker ItemsSource="{Binding PaperSizes}"
                                    SelectedItem="{Binding SelectedPaperSize}"
                                    FontSize="11" />
                            <Grid ColumnDefinitions="44,50,24,50" ColumnSpacing="2">
                                <Label Grid.Column="0" Text="Pages:" VerticalOptions="Center" FontSize="10" />
                                <Entry Grid.Column="1" Text="{Binding FromPage}" Keyboard="Numeric" FontSize="10" HeightRequest="26" Placeholder="From" />
                                <Label Grid.Column="2" Text="To:" VerticalOptions="Center" FontSize="10" HorizontalTextAlignment="Center" />
                                <Entry Grid.Column="3" Text="{Binding ToPage}" Keyboard="Numeric" FontSize="10" HeightRequest="26" Placeholder="To" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Version / Help -->
                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                    <Label Grid.Column="0" Text="Help &amp; about..." FontSize="10"
                           TextColor="{AppThemeBinding Light=Blue, Dark=LightBlue}" TextDecorations="Underline" />
                    <Label Grid.Column="1" Text="{Binding VersionText}" FontSize="10"
                           HorizontalTextAlignment="End" />
                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- RIGHT PANEL: Preview area -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto">

            <!-- Header bar -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="2,1"
                  BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}">
                <CheckBox Grid.Column="0" IsChecked="{Binding HeaderEnabled}" VerticalOptions="Center" Scale="0.75" />
                <Entry Grid.Column="1" Text="{Binding HeaderText}" FontSize="11" HeightRequest="28"
                       HorizontalTextAlignment="Center" Placeholder="Header Text" />
            </Grid>

            <!-- Print Preview -->
            <GraphicsView x:Name="PreviewGraphicsView"
                          Grid.Row="1"
                          BackgroundColor="{AppThemeBinding Light=DarkGray, Dark=#555}">
                <GraphicsView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPreviewTapped" />
                </GraphicsView.GestureRecognizers>
            </GraphicsView>

            <!-- Footer bar -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Padding="2,1"
                  BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2D2D2D}">
                <CheckBox Grid.Column="0" IsChecked="{Binding FooterEnabled}" VerticalOptions="Center" Scale="0.75" />
                <Entry Grid.Column="1" Text="{Binding FooterText}" FontSize="11" HeightRequest="28"
                       HorizontalTextAlignment="Center" Placeholder="Footer Text" />
            </Grid>

            <!-- Status Bar -->
            <Label Grid.Row="3"
                   Text="{Binding StatusText}"
                   Padding="6,2"
                   FontSize="11"
                   BackgroundColor="{AppThemeBinding Light=WhiteSmoke, Dark=#333}" />
        </Grid>

    </Grid>

</ContentPage>
