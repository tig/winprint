<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <AssemblyName>wp</AssemblyName>
        <RootNamespace>WinPrint.TUI</RootNamespace>
        <Description>winprint Terminal.Gui full-screen TUI front end (wp)</Description>
        <Platforms>AnyCPU;x64;x86</Platforms>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Terminal.Gui.Cli" Version="0.1.0-develop.5" />
        <!-- Pin the core lib to the latest release (Cli only pulls it transitively); the
             header/footer format fields use the gui-cs Editor view, which needs Terminal.Gui >= 2.4.0. -->
        <PackageReference Include="Terminal.Gui" Version="2.4.3" />
        <PackageReference Include="Terminal.Gui.Editor" Version="2.5.0" />
        <!-- Cross-platform, pure-managed PNG decode for the sixel preview (no System.Drawing). -->
        <PackageReference Include="SixLabors.ImageSharp" Version="3.1.11" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\WinPrint.Core\WinPrint.Core.csproj" />
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Include="Resources\preview-sample.png" />
    </ItemGroup>

</Project>
