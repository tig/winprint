<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Local Terminal.Gui build from the #5493 PR worktree (Kitty graphics + public
         SetSixelSupport/SetKittyGraphicsSupport API). Remove once the API ships in a
         released Terminal.Gui package.

         The feed path and package version differ per machine (different worktree
         locations / branch-derived version strings), so DO NOT hard-code them here —
         that caused Mac<->Windows build fights on every pull. Each machine sets two
         environment variables instead:

           WINPRINT_TG_FEED    = absolute path to the local Terminal.Gui bin/Debug
                                 (e.g. /Users/tig/s/gui-cs/tg-5493/Terminal.Gui/bin/Debug)
           WINPRINT_TG_VERSION = the version that worktree built
                                 (e.g. 2.4.7-tig-add-kitty-graphics-protocol-support.1)

         WINPRINT_TG_VERSION is consumed by src/WinPrint.TUI/WinPrint.TUI.csproj. -->
    <add key="tg-local" value="%WINPRINT_TG_FEED%" />
  </packageSources>
</configuration>
