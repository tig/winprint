<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!-- Entitlements used when Developer ID code-signing the MacCatalyst WinPrint.app with the
     hardened runtime (required for notarization). The .NET/Mono runtime JITs and maps
     executable memory, so it needs the allow-jit / unsigned-executable-memory /
     disable-library-validation exceptions or notarization-grade hardened signing aborts at
     launch. App Sandbox stays OFF (direct/Homebrew-cask distribution, not the App Store) so
     winprint can read arbitrary files passed on the command line. -->
<dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
